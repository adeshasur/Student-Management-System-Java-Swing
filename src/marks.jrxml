<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Student Marks Report"
              language="groovy"
              pageWidth="595" pageHeight="842"
              columnWidth="555"
              leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              uuid="5a8c1234-abcd-4f23-9001-c1234567ef89">

    <queryString><![CDATA[SELECT m.MARKID, m.STID, m.STNAME, m.CLASS, m.SUBJECT, m.MARKS
                           FROM MARKS m ORDER BY m.STNAME, m.SUBJECT]]></queryString>

    <field name="MARKID"  class="java.lang.String"/>
    <field name="STID"    class="java.lang.String"/>
    <field name="STNAME"  class="java.lang.String"/>
    <field name="CLASS"   class="java.lang.String"/>
    <field name="SUBJECT" class="java.lang.String"/>
    <field name="MARKS"   class="java.lang.String"/>

    <title>
        <band height="60" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="0" width="555" height="40" uuid="t1"/>
                <textElement verticalAlignment="Middle">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[EduManage — Student Marks Report]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="52" width="555" height="1" uuid="t2"/>
                <graphicElement>
                    <pen lineWidth="1.5"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="28" splitType="Stretch">
            <staticText>
                <reportElement x="0"   y="4" width="40"  height="20" uuid="h1"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="40"  y="4" width="50"  height="20" uuid="h2"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Stu.ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="90"  y="4" width="155" height="20" uuid="h3"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Student Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="245" y="4" width="100" height="20" uuid="h4"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Class]]></text>
            </staticText>
            <staticText>
                <reportElement x="345" y="4" width="150" height="20" uuid="h5"/>
                <textElement><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Subject]]></text>
            </staticText>
            <staticText>
                <reportElement x="495" y="4" width="60"  height="20" uuid="h6"/>
                <textElement textAlignment="Right"><font size="10" isBold="true"/></textElement>
                <text><![CDATA[Marks]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="27" width="555" height="1" uuid="hl"/>
            </line>
        </band>
    </columnHeader>

    <detail>
        <band height="22" splitType="Stretch">
            <textField>
                <reportElement x="0"   y="2" width="40"  height="18" uuid="d1"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{MARKID}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40"  y="2" width="50"  height="18" uuid="d2"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{STID}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="90"  y="2" width="155" height="18" uuid="d3"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{STNAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="245" y="2" width="100" height="18" uuid="d4"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{CLASS}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="345" y="2" width="150" height="18" uuid="d5"/>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{SUBJECT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="495" y="2" width="60"  height="18" uuid="d6"/>
                <textElement textAlignment="Right"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{MARKS}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="30" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="555" height="1" uuid="pfl"/>
            </line>
            <textField>
                <reportElement x="440" y="6" width="115" height="20" uuid="pn"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="6" width="200" height="20" uuid="foot1"/>
                <textElement><font size="9" isItalic="true"/></textElement>
                <text><![CDATA[EduManage Student Management System]]></text>
            </staticText>
        </band>
    </pageFooter>

</jasperReport>
